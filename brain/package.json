{
  "name": "ll3m-mcp-server",
  "version": "1.0.0",
  "description": "LL3M Multi-Agent 3D Modeling Server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && cp -r src/agents dist/ && cp -r src/rag dist/ && cp src/*.py dist/ 2>/dev/null || true",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "typescript": "latest",
    "@types/node": "latest"
  }
}
